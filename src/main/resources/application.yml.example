spring:
    redis:
        host: <uri>
        port: <port>
    data:
        mongodb:
            uri: <db-uri>
            database: <db-name>
            auto-index-creation: true
    datasource:
        url: <db-uri>
        username: <db-username>
        password: <db-password>
    jpa:
        hibernate:
            ddl-auto: update

    mail:
        host: <provider>
        port: <port>
        username: <email>
        password: <password>
        properties:
            mail:
                smtp:
                    auth: true
                    starttls:
                        enable: true

server:
    error:
        include-stacktrace: never